[Unit]
Description=grommunio-cui on %I
After=systemd-user-sessions.service plymouth-quit-wait.service getty-pre.target
After=rc-local.service
Wants=setlogcons.service

# If additional gettys are spawned during boot then we should make
# sure that this is synchronized before getty.target, even though
# getty.target didn't actually pull it in.
Before=getty.target
IgnoreOnIsolate=yes

# Take over the VT exclusively. Without this, the distro's stock
# getty@%i.service (enabled by preset on e.g. openSUSE Leap) also claims
# the same tty: agetty grabs the controlling terminal first, so the cui
# renders but never receives keyboard input. Conflicts stops/blocks the
# getty when we start, Before orders us ahead of it.
Conflicts=getty@%i.service
Before=getty@%i.service

# IgnoreOnIsolate causes issues with sulogin, if someone isolates
# rescue.target or starts rescue.service from multi-user.target or
# graphical.target.
Conflicts=rescue.service
Before=rescue.service

# On systems without virtual consoles, don't start any getty. Note
# that serial gettys are covered by serial-getty@.service, not this
# unit.
ConditionPathExists=/dev/tty0

[Service]
# the VT is cleared by TTYVTDisallocate
ExecStart=-@pkglibexecdir@/getty %I
Type=idle
Restart=always
RestartSec=2
UtmpIdentifier=%I
TTYPath=/dev/%I
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
IgnoreSIGPIPE=no
SendSIGHUP=yes

[Install]
WantedBy=multi-user.target
DefaultInstance=tty1
