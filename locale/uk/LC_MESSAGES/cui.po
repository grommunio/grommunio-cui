#: cui/__init__.py:333
msgid ""
"If this is not that what you expected to see, you probably have insufficient "
"permissions."
msgstr ""
"Якщо це не те, чого ви очікували, у вас, ймовірно, недостатньо дозволів."

#: cui/__init__.py:347
msgid "Main Menu"
msgstr "Головне меню"

#: cui/__init__.py:348
msgid "Here you can do the main actions"
msgstr "Тут ви можете виконати основні дії"

#: cui/__init__.py:353
msgid "Language configuration"
msgstr "Конфігурація мови"

#: cui/__init__.py:355
msgid "Language"
msgstr "Мова"

#: cui/__init__.py:358
msgid "Opens the yast2 configurator for setting language settings."
msgstr "Відкриває конфігуратор yast2 для налаштування мовних параметрів."

#: cui/__init__.py:362
msgid "Change system password"
msgstr "Зміна системного пароля'"

#: cui/__init__.py:364 cui/__init__.py:417
msgid "Password change"
msgstr "Зміна пароля"

#: cui/__init__.py:366
msgid ""
"Opens a dialog for changing the password of the system root user. When a "
"password is set, you can login via ssh and rerun grommunio-cui."
msgstr ""
"Відкриває діалогове вікно для зміни пароля системного користувача root. "
"Після встановлення пароля ви можете увійти через ssh та повторно запустити "
"grommunio-cui."

#: cui/__init__.py:369
msgid "Network interface configuration"
msgstr "Конфігурація мережевого інтерфейсу"

#: cui/__init__.py:371
msgid "Configuration of network"
msgstr "Конфігурація мережі"

#: cui/__init__.py:374
msgid ""
"Opens the yast2 configurator for setting up devices, interfaces, IP "
"addresses, DNS and more."
msgstr ""
"Відкриває конфігуратор yast2 для налаштування пристроїв, інтерфейсів, IP-"
"адрес, DNS тощо."

#: cui/__init__.py:378
msgid "Timezone configuration"
msgstr "Конфігурація часового поясу"

#: cui/__init__.py:380
msgid "Timezone"
msgstr "Часовий пояс"

#: cui/__init__.py:383
msgid "Opens the yast2 configurator for setting country and timezone settings."
msgstr "Відкриває конфігуратор yast2 для налаштування країни та часового поясу."

#: cui/__init__.py:387
msgid "timesyncd configuration"
msgstr "конфігурація синхронізації часу"

#: cui/__init__.py:389
msgid "timesyncd"
msgstr "синхронізація часу"

#: cui/__init__.py:392
msgid ""
"Opens a simple configurator for configuring systemd-timesyncd as a "
"lightweight NTP client for time synchronization."
msgstr ""
"Відкриває простий конфігуратор для налаштування systemd-timesyncd як легкого "
"NTP-клієнта для синхронізації часу."

#: cui/__init__.py:396
msgid "Select software repositories"
msgstr "Виберіть репозиторії програмного забезпечення"

#: cui/__init__.py:397
msgid "Software repositories selection"
msgstr "Вибір репозиторіїв програмного забезпечення"

#: cui/__init__.py:399
msgid "Opens dialog for choosing software repositories."
msgstr ""
"Відкриває діалогове вікно для вибору репозиторіїв програмного забезпечення."

#: cui/__init__.py:401
msgid "Update the system"
msgstr "Оновіть систему"

#: cui/__init__.py:402
msgid "System update"
msgstr "Оновлення системи"

#: cui/__init__.py:404
msgid ""
"Executes the system package manager for the installation of newer component "
"versions."
msgstr ""
"Виконує системний менеджер пакетів для встановлення новіших версій "
"компонентів."

#: cui/__init__.py:406
msgid "grommunio setup wizard"
msgstr "майстер налаштування grommunio"

#: cui/__init__.py:408
msgid "Setup wizard"
msgstr "Майстер налаштування"

#: cui/__init__.py:411
msgid ""
"Executes the grommunio-setup script for the initial configuration of "
"grommunio databases, TLS certificates, services and the administration web "
"user interface."
msgstr ""
"Виконує скрипт grommunio-setup для початкового налаштування баз даних "
"grommunio, сертифікатів TLS, служб та веб-інтерфейсу адміністрування "
"користувача."

#: cui/__init__.py:415
msgid "Change admin-web password"
msgstr "Зміна пароля адміністратора веб-сайту"

#: cui/__init__.py:420
msgid ""
"Opens a dialog for changing the password used by the administration web "
"interface."
msgstr ""
"Відкриває діалогове вікно для зміни пароля, що використовується веб-"
"інтерфейсом адміністрування."

#: cui/__init__.py:424 cui/__init__.py:426
msgid "Terminal"
msgstr "Термінал"

#: cui/__init__.py:429
msgid "Starts terminal for advanced system configuration."
msgstr "Запускає термінал для розширеної конфігурації системи."

#: cui/__init__.py:433 cui/__init__.py:1210
msgid "Reboot"
msgstr "Перезавантаження"

#: cui/__init__.py:434
msgid "Reboot system."
msgstr "Перезавантажте систему."

#: cui/__init__.py:436 cui/__init__.py:1220
msgid "Shutdown"
msgstr "Вимкнення"

#: cui/__init__.py:438
msgid "Shutdown system."
msgstr "Система вимкнення."

#: cui/__init__.py:440
msgid "Shuts down the system and powers off."
msgstr "Вимикає систему та живлення."

#: cui/__init__.py:445
msgid "Exit CUI"
msgstr "Вихід із CUI"

#: cui/__init__.py:470
msgid "grommunio console user interface"
msgstr "інтерфейс користувача консолі Grommunio"

#: cui/__init__.py:473
#, python-brace-format
msgid "Active keyboard layout: {kbd}; color set: {colormode}."
msgstr "Активна розкладка клавіатури: {kbd}; набір кольорів: {colormode}."

#: cui/__init__.py:478
msgid "If you need help, press the 'L' key to view logs."
msgstr ""
"Якщо вам потрібна допомога, натисніть клавішу «L», щоб переглянути журнали."

